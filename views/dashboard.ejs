<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Finance Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>
    <%- include('layouts/header') %>

        <div class="container">
            <div class="dashboard-header">
                <h1>Company Financial Dashboard</h1>
                <p>Welcome, <%= user.username %>!</p>
            </div>

            <!-- Summary Cards -->
            <div class="summary-cards">
                <div class="card card-income">
                    <h3>Total Income</h3>
                    <p class="amount">₹<%= totalIncome.toFixed(2) %>
                    </p>
                </div>

                <div class="card card-expense">
                    <h3>Total Expenses</h3>
                    <p class="amount">₹<%= totalExpense.toFixed(2) %>
                    </p>
                </div>

                <div class="card card-balance <%= netBalance >= 0 ? 'positive' : 'negative' %>">
                    <h3>Net Balance</h3>
                    <p class="amount">₹<%= netBalance.toFixed(2) %>
                    </p>
                </div>
            </div>

            <!-- Charts Section -->
            <div class="charts-section">
                <div class="chart-container">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                        <h3 style="margin: 0;">Category Breakdown</h3>
                        <div>
                            <button id="tab-expense" class="btn btn-sm btn-danger" onclick="switchCategoryTab('expense')">Expense</button>
                            <button id="tab-income" class="btn btn-sm btn-secondary" onclick="switchCategoryTab('income')">Income</button>
                        </div>
                    </div>
                    <canvas id="categoryChart"></canvas>
                </div>

                <div class="chart-container">
                    <h3>Monthly Trends</h3>
                    <canvas id="monthlyChart"></canvas>
                </div>
            </div>

            <!-- Recent Transactions -->
            <div class="recent-transactions">
                <h3>Recent Transactions</h3>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Category</th>
                            <th>Type</th>
                            <th>Amount</th>
                            <th>Created By</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% recentTransactions.forEach(transaction=> { %>
                            <tr>
                                <td>
                                    <%= new Date(transaction.date).toLocaleDateString() %>
                                </td>
                                <td>
                                    <%= transaction.category %>
                                </td>
                                <td>
                                    <span
                                        class="badge <%= transaction.type === 'income' ? 'badge-success' : 'badge-danger' %>">
                                        <%= transaction.type.toUpperCase() %>
                                    </span>
                                </td>
                                <td>₹<%= parseFloat(transaction.amount).toFixed(2) %>
                                </td>
                                <td>
                                    <%= transaction.username %>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>
            </div>

            <div class="action-buttons">
                <a href="/records" class="btn btn-primary">View All Records</a>
            </div>
        </div>

        <%- include('layouts/footer') %>

            <script>
                // Category Breakdown Chart
                const categoryData = <%- JSON.stringify(categoryBreakdown) %>;
                
                const incomeData = categoryData.filter(d => d.type === 'income');
                const expenseData = categoryData.filter(d => d.type === 'expense');

                const incomeLabels = incomeData.map(d => d.category);
                const incomeTotals = incomeData.map(d => d.total);
                
                const expenseLabels = expenseData.map(d => d.category);
                const expenseTotals = expenseData.map(d => d.total);

                const categoryCtx = document.getElementById('categoryChart').getContext('2d');
                let categoryChart = new Chart(categoryCtx, {
                    type: 'bar',
                    data: {
                        labels: expenseLabels,
                        datasets: [{
                            label: 'Expense',
                            data: expenseTotals,
                            backgroundColor: '#f44336',
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true } }
                    }
                });

                function switchCategoryTab(type) {
                    const btnExpense = document.getElementById('tab-expense');
                    const btnIncome = document.getElementById('tab-income');

                    if (type === 'expense') {
                        btnExpense.className = 'btn btn-sm btn-danger';
                        btnIncome.className = 'btn btn-sm btn-secondary';
                        
                        categoryChart.data.labels = expenseLabels;
                        categoryChart.data.datasets[0].label = 'Expense';
                        categoryChart.data.datasets[0].data = expenseTotals;
                        categoryChart.data.datasets[0].backgroundColor = '#f44336';
                    } else {
                        btnExpense.className = 'btn btn-sm btn-secondary';
                        btnIncome.className = 'btn btn-sm btn-success';

                        categoryChart.data.labels = incomeLabels;
                        categoryChart.data.datasets[0].label = 'Income';
                        categoryChart.data.datasets[0].data = incomeTotals;
                        categoryChart.data.datasets[0].backgroundColor = '#4CAF50';
                    }
                    categoryChart.update();
                }

                // Monthly Trends Chart
                const monthlyData = <%- JSON.stringify(monthlyTrends) %>;
                const months = [...new Set(monthlyData.map(d => d.month))].reverse();
                
                const incomeByMonth = months.map(month => {
                    const item = monthlyData.find(d => d.month === month && d.type === 'income');
                    return item ? item.total : 0;
                });
                
                const expenseByMonth = months.map(month => {
                    const item = monthlyData.find(d => d.month === month && d.type === 'expense');
                    return item ? item.total : 0;
                });

                const monthlyCtx = document.getElementById('monthlyChart').getContext('2d');
                new Chart(monthlyCtx, {
                    type: 'line',
                    data: {
                        labels: months,
                        datasets: [
                            {
                                label: 'Income',
                                data: incomeByMonth,
                                borderColor: '#4CAF50',
                                backgroundColor: 'rgba(76, 175, 80, 0.1)',
                                borderWidth: 2,
                                tension: 0.4
                            },
                            {
                                label: 'Expense',
                                data: expenseByMonth,
                                borderColor: '#f44336',
                                backgroundColor: 'rgba(244, 67, 54, 0.1)',
                                borderWidth: 2,
                                tension: 0.4
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { position: 'top' }
                        },
                        scales: {
                            y: { beginAtZero: true }
                        }
                    }
                });
            </script>
</body>

</html>