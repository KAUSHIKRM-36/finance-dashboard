<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Records - Finance Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('layouts/header') %>

        <div class="container">
            <div class="records-header">
                <h1>Financial Records</h1>
                <% if (user.role==='admin' ) { %>
                    <button class="btn btn-primary" onclick="showCreateForm()">+ Create Record</button>
                    <% } else { %>
                        <span class="text-muted" style="font-size: 0.9em; align-self: center;">Only admins can create
                            records</span>
                        <% } %>
            </div>

            <!-- Filters -->
            <div class="filters-section">
                <h3>Filters</h3>
                <form method="GET" action="/records" class="filter-form">
                    <div class="form-group">
                        <label for="category">Category</label>
                        <input type="text" id="category" name="category" placeholder="Filter by category"
                            value="<%= filters.category || '' %>">
                    </div>

                    <div class="form-group">
                        <label for="type">Type</label>
                        <select id="type" name="type">
                            <option value="">All Types</option>
                            <option value="income" <%=filters.type==='income' ? 'selected' : '' %>>Income</option>
                            <option value="expense" <%=filters.type==='expense' ? 'selected' : '' %>>Expense</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="dateFrom">From Date</label>
                        <input type="date" id="dateFrom" name="dateFrom" value="<%= filters.dateFrom || '' %>">
                    </div>

                    <div class="form-group">
                        <label for="dateTo">To Date</label>
                        <input type="date" id="dateTo" name="dateTo" value="<%= filters.dateTo || '' %>">
                    </div>

                    <button type="submit" class="btn btn-secondary">Apply Filters</button>
                    <a href="/records" class="btn btn-secondary">Reset</a>
                </form>
            </div>

            <!-- Records Table -->
            <div class="records-table">
                <h3>All Company Records</h3>
                <% if (records.length> 0) { %>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Category</th>
                                <th>Type</th>
                                <th>Amount</th>
                                <th>Description</th>
                                <th>Created By</th>
                                <% if (user.role !=='viewer' ) { %>
                                    <th>Actions</th>
                                    <% } %>
                            </tr>
                        </thead>
                        <tbody>
                            <% records.forEach(record=> { %>
                                <tr>
                                    <td>
                                        <%= new Date(record.date).toLocaleDateString() %>
                                    </td>
                                    <td>
                                        <%= record.category %>
                                    </td>
                                    <td>
                                        <span
                                            class="badge <%= record.type === 'income' ? 'badge-success' : 'badge-danger' %>">
                                            <%= record.type.toUpperCase() %>
                                        </span>
                                    </td>
                                    <td><strong>₹<%= parseFloat(record.amount).toFixed(2) %></strong></td>
                                    <td>
                                        <%= record.description || '-' %>
                                    </td>
                                    <td>
                                        <%= record.created_by %>
                                    </td>
                                    <% if (user.role !=='viewer' ) { %>
                                        <td>
                                            <% if (user.role==='analyst' && record.user_id===user.id ||
                                                user.role==='admin' ) { %>
                                                <button class="btn btn-sm btn-info"
                                                    onclick="editRecord(<%= record.id %>)">Edit</button>
                                                <button class="btn btn-sm btn-danger"
                                                    onclick="deleteRecord(<%= record.id %>)">Delete</button>
                                                <% } else if (user.role==='analyst' ) { %>
                                                    <span class="text-muted">Not yours</span>
                                                    <% } %>
                                        </td>
                                        <% } %>
                                </tr>
                                <% }); %>
                        </tbody>
                    </table>
                    <% } else { %>
                        <p class="empty-state">No records found. Create your first record!</p>
                        <% } %>
            </div>
        </div>

        <!-- Create/Edit Modal -->
        <div id="recordModal" class="modal">
            <div class="modal-content">
                <span class="close" onclick="closeModal()">&times;</span>
                <h2 id="modalTitle">Create Record</h2>

                <form id="recordForm" onsubmit="submitRecord(event)">
                    <div class="form-group">
                        <label for="amount">Amount</label>
                        <input type="number" id="amount" name="amount" step="0.01" required>
                    </div>

                    <div class="form-group">
                        <label for="recordType">Type</label>
                        <select id="recordType" name="type" required>
                            <option value="">Select Type</option>
                            <option value="income">Income</option>
                            <option value="expense">Expense</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="recordCategory">Category</label>
                        <select id="recordCategory" name="category" required>
                            <option value="">First select a Type</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="recordDate">Date</label>
                        <input type="date" id="recordDate" name="date" required>
                    </div>

                    <div class="form-group">
                        <label for="recordDescription">Description</label>
                        <textarea id="recordDescription" name="description" placeholder="Optional details"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary">Save Record</button>
                    <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
                </form>
            </div>
        </div>

        <script>
            const categoryMapping = {
                'expense': ['Operations', 'Travel / Marketing', 'Payroll / Staff'],
                'income': ['Sales / Revenue', 'Investments / Returns', 'Other Income']
            };

            document.getElementById('recordType').addEventListener('change', function () {
                const type = this.value;
                const categorySelect = document.getElementById('recordCategory');
                categorySelect.innerHTML = '<option value="">Select Category</option>';

                if (categoryMapping[type]) {
                    categoryMapping[type].forEach(cat => {
                        const opt = document.createElement('option');
                        opt.value = cat;
                        opt.textContent = cat;
                        categorySelect.appendChild(opt);
                    });
                } else {
                    categorySelect.innerHTML = '<option value="">First select a Type</option>';
                }
            });
        </script>

        <%- include('layouts/footer') %>

            <script src="/js/script.js"></script>
</body>

</html>